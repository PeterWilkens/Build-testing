<?xml version="1.0" encoding="utf-8"?>
<section xml:id="sec-major-minor-triads" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Major and Minor Triads</title>
  <introduction>
    <p>These triad shapes are moveable: the shape stays the same regardless of which button you start on, taking the name of the root note. The first row shows the four root-position triad types; the second row shows their common inversions.</p>
  </introduction>

  <!-- ===== Row 1: Root positions ===== -->
  <figure xml:id="fig-triad-grids-row1">
    <caption></caption>
    <sidebyside widths="22% 22% 22% 22%" margins="3%">

      <!-- Grid 1: C Major (C, E, G) -->
      <image xml:id="img-triad-cmaj">
        <latex-image>
\begin{tikzpicture}[scale=0.65, transform shape]
\pgfmathsetmacro{\isoangle}{60}
\pgfmathsetmacro{\vv}{8}
\pgfmathsetmacro{\hh}{6}
\pgfmathsetmacro{\vlen}{0.85}
\pgfmathsetmacro{\ang}{\isoangle/2}
\pgfmathsetmacro{\dlen}{(\vlen/2) / sin(\ang)}
\pgfmathsetmacro{\hlen}{(\vlen/2) / tan(\ang)}
\pgfmathsetmacro{\xmax}{\hh*\hlen}
\pgfmathsetmacro{\ymax}{\vv*\vlen}
\drawgridandnotes
\gn{5}{1.5}{C}{1}
\gn{4}{2}{C$\sharp$, D$\flat$}{0}
\gn{3}{2.5}{D}{0}
\gn{2}{3}{E$\flat$, D$\sharp$}{0}
\gn{1}{3.5}{E}{0}
\gn{5}{2.5}{E$\flat$, D$\sharp$}{0}
\gn{4}{3}{E}{1}
\gn{3}{3.5}{F}{0}
\gn{2}{4}{G$\flat$, F$\sharp$}{0}
\gn{1}{4.5}{G}{0}
\gn{5}{3.5}{G$\flat$, F$\sharp$}{0}
\gn{4}{4}{G}{1}
\gn{3}{4.5}{A$\flat$, G$\sharp$}{0}
\gn{2}{5}{A}{0}
\gn{1}{5.5}{B$\flat$, A$\sharp$}{0}
\gn{5}{4.5}{A}{0}
\gn{4}{5}{B$\flat$, A$\sharp$}{0}
\gn{3}{5.5}{B}{0}
\gn{2}{6}{C}{0}
\gn{1}{6.5}{C$\sharp$, D$\flat$}{0}
\gn{5}{5.5}{C}{0}
\gn{4}{6}{C$\sharp$, D$\flat$}{0}
\gn{3}{6.5}{D}{0}
\gn{2}{7}{E$\flat$, D$\sharp$}{0}
\gn{1}{7.5}{E}{0}
\gn{5}{6.5}{E$\flat$, D$\sharp$}{0}
\gn{4}{7}{E}{0}
\gn{3}{7.5}{F}{0}
\gn{2}{8}{G$\flat$, F$\sharp$}{0}
\gn{1}{8.5}{G}{0}
\end{tikzpicture}
        </latex-image>
      </image>

