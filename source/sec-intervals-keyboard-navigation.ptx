\pgfmathsetmacro{\xmax}{\hh*\hlen}
\pgfmathsetmacro{\ymax}{\vv*\vlen}
\drawgridandnotes
\gn{1}{1.5}{C}{1}
\gn{2}{2}{C$\sharp$, D$\flat$}{1}
\gn{3}{2.5}{D}{1}
\gn{4}{3}{E$\flat$, D$\sharp$}{1}
\gn{1}{2.5}{E$\flat$, D$\sharp$}{0}
\gn{2}{3}{E}{0}
\gn{3}{3.5}{F}{0}
\gn{4}{4}{G$\flat$, F$\sharp$}{0}
\gn{1}{3.5}{G$\flat$, F$\sharp$}{1}
\gn{2}{4}{G}{0}
\gn{3}{4.5}{A$\flat$, G$\sharp$}{0}
\gn{4}{5}{A}{0}
\gn{1}{4.5}{A}{0}
\gn{2}{5}{B$\flat$, A$\sharp$}{1}
\gn{3}{5.5}{B}{0}
\gn{4}{6}{C}{0}
\gn{1}{5.5}{C}{0}
\gn{2}{6}{C$\sharp$, D$\flat$}{0}
\gn{3}{6.5}{D}{1}
\gn{4}{7}{E$\flat$, D$\sharp$}{0}
\gn{1}{6.5}{E$\flat$, D$\sharp$}{0}
\gn{2}{7}{E}{0}
\gn{3}{7.5}{F}{0}
\gn{4}{8}{G$\flat$, F$\sharp$}{1}
% Bellows markers (centre)
\draw[gray, thin] (5.4*\hlen, 2.1*\vlen) -- (5.4*\hlen, 8.5*\vlen);
\draw[gray, thin] (5.7*\hlen, 2.1*\vlen) -- (5.7*\hlen, 8.5*\vlen);
\draw[gray, thin] (6.0*\hlen, 2.1*\vlen) -- (6.0*\hlen, 8.5*\vlen);
% Interval brackets
\pgfmathsetmacro{\halfnode}{11/72.27*2.54}
\pgfmathsetmacro{\brgap}{0.04}
\pgfmathsetmacro{\brarm}{0.25}
\pgfmathsetmacro{\brarmin}{0.14}
% Col 1 left: tritone C-F# (2 stacked minor thirds)
\draw[gray] ({1*\hlen-\halfnode-\brgap}, {1.5*\vlen}) -- ({1*\hlen-\halfnode-\brgap-\brarm}, {1.5*\vlen}) -- ({1*\hlen-\halfnode-\brgap-\brarm}, {3.5*\vlen}) -- ({1*\hlen-\halfnode-\brgap}, {3.5*\vlen});
% Col 2 left: dim 7th C#-Bb (3 stacked minor thirds)
\draw[gray] ({2*\hlen-\halfnode-\brgap}, {2.0*\vlen}) -- ({2*\hlen-\halfnode-\brgap-\brarmin}, {2.0*\vlen}) -- ({2*\hlen-\halfnode-\brgap-\brarmin}, {5.0*\vlen}) -- ({2*\hlen-\halfnode-\brgap}, {5.0*\vlen});
% Col 3 left: octave D-D (4 stacked minor thirds)
\draw[gray] ({3*\hlen-\halfnode-\brgap}, {2.5*\vlen}) -- ({3*\hlen-\halfnode-\brgap-\brarm}, {2.5*\vlen}) -- ({3*\hlen-\halfnode-\brgap-\brarm}, {6.5*\vlen}) -- ({3*\hlen-\halfnode-\brgap}, {6.5*\vlen});
% Col 4 left: Eb to high Gb (5 minor thirds)
\draw[gray] ({4*\hlen-\halfnode-\brgap}, {3.0*\vlen}) -- ({4*\hlen-\halfnode-\brgap-\brarmin}, {3.0*\vlen}) -- ({4*\hlen-\halfnode-\brgap-\brarmin}, {8.0*\vlen}) -- ({4*\hlen-\halfnode-\brgap}, {8.0*\vlen});
\end{tikzpicture}
        </latex-image>
      </image>

