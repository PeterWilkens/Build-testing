\draw[gray, very thick, ->] ({1*\hlen + sqrt(3)/2*\noderadius}, {2.5*\vlen + 0.5*\noderadius}) -- ({4*\hlen - sqrt(3)/2*\noderadius}, {4.0*\vlen - 0.5*\noderadius});
\end{tikzpicture}

