  <figure xml:id="fig-nav-pair-3">
    <caption>Stacking minor 3rds. A summary</caption>
    <sidebyside widths="45% 45%" margins="2%">

      <!-- Free Bass keyboard â€” columns mirrored, bellows right (centre) -->
      <image xml:id="img-nav-freebass-3">
        <latex-image>
\begin{tikzpicture}[scale=0.60, transform shape]
\pgfmathsetmacro{\isoangle}{60}
\pgfmathsetmacro{\vv}{8}
\pgfmathsetmacro{\hh}{6}
\pgfmathsetmacro{\vlen}{0.85}
\pgfmathsetmacro{\ang}{\isoangle/2}
