    \templatenodestyle{4}{10.0}{}{3}
    \templatenodestyle{5}{10.5}{}{3}
    \templatenodestyle{6}{11.0}{}{3}

    \templatenodestyle{1}{9.5}{C}{2}
    \templatenodestyle{2}{10.0}{}{3}
    \templatenodestyle{3}{10.5}{D}{2}
    \templatenodestyle{4}{11.0}{}{3}
    \templatenodestyle{5}{11.5}{}{3}
    \templatenodestyle{6}{12.0}{}{3}

  \node[anchor=north, rotate=90, font=\bfseries\scriptsize] at (5*\hlen,2.2*\vlen) {Bass};
  \node[anchor=north, rotate=90, font=\bfseries\scriptsize] at (6*\hlen,2.2*\vlen) {Counter Bass};
\end{scope}

