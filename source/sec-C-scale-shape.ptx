  \node[circle,draw=gray,fill=gray!10,inner sep=1pt,minimum size=40pt] at (4*\hlen,10.0*\vlen) {C$\sharp$, D$\flat$};
  \node[circle,draw=gray,fill=gray!10,inner sep=1pt,minimum size=40pt] at (3*\hlen,10.5*\vlen) {D};
  \node[circle,draw=gray,fill=gray!10,inner sep=1pt,minimum size=40pt] at (2*\hlen,11.0*\vlen) {E$\flat$, D$\sharp$};
