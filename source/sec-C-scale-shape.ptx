  % Row 10 (+4)
  \node[circle,draw=gray,fill=gray!10,inner sep=1pt,minimum size=40pt] at (5*\hlen,10.5*\vlen) {E$\flat$, D$\sharp$};
  \node[circle,draw=gray,fill=gray!10,inner sep=1pt,minimum size=40pt] at (4*\hlen,11.0*\vlen) {E};
  \node[circle,draw=gray,fill=gray!10,inner sep=1pt,minimum size=40pt] at (3*\hlen,11.5*\vlen) {F};
  \node[circle,draw=gray,fill=gray!10,inner sep=1pt,minimum size=40pt] at (2*\hlen,12.0*\vlen) {G$\flat$, F$\sharp$};
  \node[circle,draw=gray,fill=gray!10,inner sep=1pt,minimum size=40pt] at (1*\hlen,12.5*\vlen) {G};
\end{scope}

% Bellows separator — five gray!40 vertical lines 0.15cm apart with legend
% Note at bottom of treble side
\node[anchor=west, font=\small\bfseries] at (7.75*\hlen+1.5,0.5*\vlen) {Scale shows note and finger to be used};
\pgfmathsetmacro{\belbot}{1.0*\vlen}
\pgfmathsetmacro{\beltop}{13.5*\vlen}
\draw[gray!40, very thick] (\belx-0.60, \belbot) -- (\belx-0.60, \beltop);
\draw[gray!40, very thick] (\belx-0.45, \belbot) -- (\belx-0.45, \beltop);
\draw[gray!40, very thick] (\belx-0.30, \belbot) -- (\belx-0.30, \beltop);
\draw[gray!40, very thick] (\belx-0.15, \belbot) -- (\belx-0.15, \beltop);
\draw[gray!40, very thick] (\belx,      \belbot) -- (\belx,      \beltop);
\node[font=\small, black] at (\belx-0.30, 0.5*\vlen) {Bellows};

\end{tikzpicture}
