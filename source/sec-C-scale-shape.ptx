  \node[circle,draw=gray,fill=gray!10,inner sep=1pt,minimum size=40pt] at (1*\hlen,9.5*\vlen) {B$\flat$, A$\sharp$};
  % Row 8 (+2)
  \node[circle,draw=gray,fill=gray!50,inner sep=1pt,minimum size=40pt] at (5*\hlen,8.5*\vlen) {A\textbf{\large 4}};
  \node[circle,draw=gray,fill=gray!10,inner sep=1pt,minimum size=40pt] at (4*\hlen,9.0*\vlen) {B$\flat$, A$\sharp$};
  \node[circle,draw=gray,fill=gray!50,inner sep=1pt,minimum size=40pt] at (3*\hlen,9.5*\vlen) {B\textbf{\large 3}};
