  \node[circle,draw=gray,fill=gray!10,inner sep=1pt,minimum size=40pt] at (3*\hlen,3.5*\vlen) {F\textbf{\large 2}};
  \node[circle,draw=gray,fill=gray!10,inner sep=1pt,minimum size=40pt] at (2*\hlen,4.0*\vlen) {G$\flat$, F$\sharp$};
