  \node[circle,draw=gray,fill=gray!10,inner sep=1pt,minimum size=40pt] at (4*\hlen,6.0*\vlen) {C$\sharp$, D$\flat$};
  \node[circle,draw=gray,fill=gray!50,inner sep=1pt,minimum size=40pt] at (3*\hlen,6.5*\vlen) {D\textbf{\large 3}};
  \node[circle,draw=gray,fill=gray!10,inner sep=1pt,minimum size=40pt] at (2*\hlen,7.0*\vlen) {E$\flat$, D$\sharp$};
