<?xml version="1.0" encoding="UTF-8"?>

<chapter xml:id="ch-chord-builds">
    <title>Chord Builds</title>
    
    <section xml:id="sec-chord-builds-intro">
        <title>Chord Builds
        </title>
        <p>
            An isometric grid visualization created using TiKZ.
        </p>
        
        <figure xml:id="fig-chord-builds">
            <caption>Chord Builds
            </caption>
            <image xml:id="img-chord-builds">
                <latex-image>
\begin{tikzpicture}
% User-adjustable parameters
\pgfmathsetmacro{\isoangle}{60} % theta
\pgfmathsetmacro{\vv}{10} % # vertical segments 
\pgfmathsetmacro{\hh}{6} % # horizontal segments 
\pgfmathsetmacro{\vlen}{1.5} % vertical length

% Set up for isometric grid
\pgfmathsetmacro{\ang}{\isoangle/2} 
\pgfmathsetmacro{\dlen}{(\vlen/2) / sin(\ang)}
\pgfmathsetmacro{\hlen}{(\vlen/2) / tan(\ang)}
\pgfmathsetmacro{\xmax}{\hh*\hlen}
\pgfmathsetmacro{\ymax}{\vv*\vlen}

    \begin{scope}
        % set drawing region (clipped outside)
        \path[clip] (0,0) rectangle (\xmax,\ymax);

        % interior vertical lines
        \pgfmathsetmacro{\ii}{\hh-1}
        \foreach \i in {1,...,\ii} {
          \draw[lightgray,very thin] (\i*\hlen,0) -- ++(0,\ymax);
        }

        % Rightward lines from bottom and top
        \pgfmathsetmacro{\dvlen}{2*\vv*\dlen}
        \foreach \i in {0,2,...,\hh} {
            \draw[lightgray,very thin] (\i*\hlen,0) -- ++(\ang:\dvlen); 
            \draw[lightgray,very thin] (\i*\hlen,\ymax) -- ++(-\ang:\dvlen); 
        }

        % Lines from left side
        \pgfmathsetmacro{\jj}{\vv-1}
        \pgfmathsetmacro{\dhlen}{\hh*\dlen}
        \foreach \j in {1,...,\jj} {
            \draw[lightgray,very thin] (0,\j*\vlen) -- ++(\ang:\dhlen); 
            \draw[lightgray,very thin] (0,\j*\vlen) -- ++(-\ang:\dhlen); 
        }
    \end{scope}

    % outline
    \draw[lightgray,very thin] rectangle (\xmax,\ymax);	

    % labeling intersections
    \foreach \i in {0,1,...,\hh} {
        \pgfmathsetmacro{\jj}{mod(\i,2)==0?\vv:\vv-1}
        \pgfmathsetmacro{\ff}{mod(\i,2)==0?0:\vlen/2}
        \foreach \j in {0,1,...,\jj} {
            \path (\i*\hlen,\j*\vlen+\ff) 
            coordinate (I-\i-\j);
        }
    }

    % Draw Isometric Axes
    \begin{scope}[shift=(I-3-2), every path/.style={blue, ultra thick, ->}, every node/.append style={pos=1.25, fill=white}]
       % \draw (0,0) -- (90:2) node {$z$};
       % \draw (0,0) -- ++(-\ang:2) node {$x$};
       %\draw (0,0) -- ++(180+\ang:2) node {$y$};
    \end{scope}




    
    
    \node[circle, draw=green, fill=green!10, inner sep=1pt, minimum size=40pt] at (I-5-1.5) {C I-5-1.5};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-4-2) {C\sh, D\fl};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-3-2.5) {D I-3-2.5};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-2-3) {E\fl, D\sh};
    \node[circle, draw=green, fill=green!10, inner sep=1pt, minimum size=40pt] at (I-1-3) {E I-1-3};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-5-2) {E\fl,D\sh};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-4-3) {E I-4-3};
    \node[circle, draw=green, fill=green!10, inner sep=1pt, minimum size=40pt] at (I-3-3) {F I-3-3};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-2-4) {G\fl, F\sh};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-1-4) {G I-1-4};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-1-6) {E I-1-6};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-2-4) {G\fl,F\sh};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-5-3) {G\fl, F\sh};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-4-4) {G I-4-4};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-4-3) {E I-4-3};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-3-4) {A\fl, G\sh};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-2-5) {A I-2-5};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-1-5) {B\fl, A\sh};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-5-4) {A I-5-4};
    % Diagonal sequence from I-5-4
   \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-4-5) {A\sh, B\fl};
 \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-3-5) {BI-3-5};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-2-6) {C I-2-6};
   \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-1-6) {C\sh,D\fl};
    % Diagonal nodes above C-E diagonal: Efl, F, Fsh, G, Gsh, A, Ash, Bfl
   \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-5-5) {C I-5-5};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-4-6) {C\sh,D\fl};
   \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-3-6) {D I-3-6};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-2-7) {D\sh,E\fl};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-1-7){E I-1-7};

    % Row
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-1-8) {G I-1-8};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-3-7) {F I-3-7};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-4-7) {E};

    % Row 9
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-5-6) {E\fl,D\sh};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-4-8) {G I-4-8};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-2-8) {F\sh,G\fl};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-5-7) {F\sh,G\fl};

\node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-3-8) {A\fl, G\sh};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-2-9) {A I-2-9};
    \node[circle, draw=green, fill=green!10, inner sep=1pt,minimum size=40pt] at (I-1-9) {B\fl, A\sh};

    \end{tikzpicture}
                


</latex-image>
            </image>

        </figure>
    </section>
    
</chapter>
