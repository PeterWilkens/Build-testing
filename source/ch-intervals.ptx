\pgfmathsetmacro{\hlen}{(\vlen/2)/tan(\ang)}  % ~1.299 cm – row height after rotation
\pgfmathsetmacro{\halfstep}{\vlen/2}   % 0.75 cm – basic column unit
\pgfmathsetmacro{\nrows}{5}            % peg rows (p=1 top .. p=5 bottom)
\pgfmathsetmacro{\ncyc}{10}            % 10 node cycles along bottom row
% Grid extents (cm)
\pgfmathsetmacro{\gridH}{(\nrows-1)*\hlen}          % vertical span 4*hlen
\pgfmathsetmacro{\kmin}{3}                           % first column index k
\pgfmathsetmacro{\kmax}{21}                          % last column index k  (bottom row r=10)
\pgfmathsetmacro{\gridW}{(\kmax-\kmin)*\halfstep}   % = 18*0.75 = 13.5 cm
\pgfmathsetmacro{\xleft}{0}
\pgfmathsetmacro{\xright}{\gridW}
\pgfmathsetmacro{\ybottom}{0}
\pgfmathsetmacro{\ytop}{\gridH}
