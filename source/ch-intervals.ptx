\fi\fi
%
% gnvisBiv  k=9  C5  pos=5  stem=down
\ifnum\gnvisBiv=1\ifnum\nvisIX=1
  \filldraw[black] ({6*\halfstep},{\staffbottom+5*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(6*\halfstep)-0.13},{\staffbottom+5*\hstep}) -- ({(6*\halfstep)-0.13},{\staffbottom+5*\hstep-0.9});
\fi\fi
%
% gnvisAiv  k=10  C#5  pos=5  stem=down
\ifnum\gnvisAiv=1\ifnum\nvisX=1
  \filldraw[black] ({7*\halfstep},{\staffbottom+5*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(7*\halfstep)-0.13},{\staffbottom+5*\hstep}) -- ({(7*\halfstep)-0.13},{\staffbottom+5*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\small] at ({(7*\halfstep)-0.22},{\staffbottom+5*\hstep+0.05}) {$\boldsymbol{\sharp}$};
\fi\fi
%
% gnvisCv  k=10  D5  pos=6  stem=down
\ifnum\gnvisCv=1\ifnum\nvisX=1
  \filldraw[black] ({7*\halfstep},{\staffbottom+6*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(7*\halfstep)-0.13},{\staffbottom+6*\hstep}) -- ({(7*\halfstep)-0.13},{\staffbottom+6*\hstep-0.9});
