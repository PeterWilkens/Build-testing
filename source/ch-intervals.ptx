\ifnum\gnvisAv=1\ifnum\nvisXII=1
  \filldraw[black] ({9*\halfstep},{\staffbottom+7*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(9*\halfstep)-0.13},{\staffbottom+7*\hstep}) -- ({(9*\halfstep)-0.13},{\staffbottom+7*\hstep-0.9});
\fi\fi
