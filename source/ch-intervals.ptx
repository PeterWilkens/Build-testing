  \filldraw[black] ({14*\halfstep},{\staffbottom+12*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(14*\halfstep)-0.13},{\staffbottom+12*\hstep}) -- ({(14*\halfstep)-0.13},{\staffbottom+12*\hstep-0.9});
\fi\fi
%
% gnvisAviii  k=18  C#6  pos=12  stem=down
\ifnum\gnvisAviii=1\ifnum\nvisXVIII=1
  \draw[black,thin] ({(15*\halfstep)-0.20},{\staffbottom+10*\hstep}) -- ({(15*\halfstep)+0.20},{\staffbottom+10*\hstep});
  \draw[black,thin] ({(15*\halfstep)-0.20},{\staffbottom+12*\hstep}) -- ({(15*\halfstep)+0.20},{\staffbottom+12*\hstep});
  \filldraw[black] ({15*\halfstep},{\staffbottom+12*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(15*\halfstep)-0.13},{\staffbottom+12*\hstep}) -- ({(15*\halfstep)-0.13},{\staffbottom+12*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\small] at ({(15*\halfstep)-0.22},{\staffbottom+12*\hstep+0.05}) {$\boldsymbol{\sharp}$};
\fi\fi
%
% gnvisCix  k=18  D6  pos=13  stem=down
\ifnum\gnvisCix=1\ifnum\nvisXVIII=1
  \draw[black,thin] ({(15*\halfstep)-0.20},{\staffbottom+10*\hstep}) -- ({(15*\halfstep)+0.20},{\staffbottom+10*\hstep});
  \draw[black,thin] ({(15*\halfstep)-0.20},{\staffbottom+12*\hstep}) -- ({(15*\halfstep)+0.20},{\staffbottom+12*\hstep});
  \filldraw[black] ({15*\halfstep},{\staffbottom+13*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(15*\halfstep)-0.13},{\staffbottom+13*\hstep}) -- ({(15*\halfstep)-0.13},{\staffbottom+13*\hstep-0.9});
\fi\fi
%
% gnvisEx  k=18  Eb6  pos=14  stem=down
\ifnum\gnvisEx=1\ifnum\nvisXVIII=1
  \draw[black,thin] ({(15*\halfstep)-0.20},{\staffbottom+10*\hstep}) -- ({(15*\halfstep)+0.20},{\staffbottom+10*\hstep});
  \draw[black,thin] ({(15*\halfstep)-0.20},{\staffbottom+12*\hstep}) -- ({(15*\halfstep)+0.20},{\staffbottom+12*\hstep});
  \draw[black,thin] ({(15*\halfstep)-0.20},{\staffbottom+14*\hstep}) -- ({(15*\halfstep)+0.20},{\staffbottom+14*\hstep});
  \filldraw[black] ({15*\halfstep},{\staffbottom+14*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(15*\halfstep)-0.13},{\staffbottom+14*\hstep}) -- ({(15*\halfstep)-0.13},{\staffbottom+14*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\small] at ({(15*\halfstep)-0.22},{\staffbottom+14*\hstep+0.05}) {$\boldsymbol{\flat}$};
\fi\fi
\end{scope}

% ---- Connecting vertical lines from staff notes down to grid ----
% Draw a light vertical line from below each note head down to the top of the grid
% at the same x position; note range after shift is k*\halfstep for k=3..18
\foreach \k in {0,...,18} {
  \pgfmathsetmacro{\nxx}{\k*\halfstep}
  \draw[lightgray!60, very thin] (\nxx, \ytop) -- (\nxx, {\staffbottom - 2*\hstep - 0.24});
}

% Bounding box
\pgfmathsetmacro{\bbleft}{\xleft - 1.75}
\pgfmathsetmacro{\bbtop}{\staffbottom + 14*\hstep + 0.6}
\useasboundingbox (\bbleft, \ybottom - 0.5) rectangle ({\xright + 0.15}, \bbtop);

\end{tikzpicture}
