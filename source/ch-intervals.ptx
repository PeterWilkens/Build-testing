% ---- TOP label on left of grid ----
\node[anchor=center, rotate=90, font=\small\bfseries] at ({\xleft - 1.35}, {(\ytop)/2}) {Top of Accordion};

% ---- Treble staff above the grid ----
% Staff: 5 lines, gap=staffgap cm; bottom staff line (E4) above ytop
\pgfmathsetmacro{\staffgap}{0.25}                     % cm between staff lines
\pgfmathsetmacro{\staffbottom}{\ytop + 2.0}           % cm above grid top (gap between grid and staff)
\pgfmathsetmacro{\staffleft}{\xleft - 1.2}            % extended left to give room for clef before C4
\pgfmathsetmacro{\staffright}{\xright + 0.04}

\foreach \sl in {0,...,4} {
  \draw[black, thin] (\staffleft, \staffbottom + \sl*\staffgap)
                  -- (\staffright, \staffbottom + \sl*\staffgap);
}

% Treble clef – anchored at start of staff lines, raised so G-line sits on 2nd staff line
\node[anchor=base west, inner sep=0pt] at ({\staffleft + 0.04}, {\staffbottom + 2*\staffgap - 0.10}) {%
  \raisebox{-4pt}{\begingroup\normalmusicsize\fontsize{22}{22}\selectfont\trebleclef\endgroup}%
};

% ---- Notes above staff: each highlighted node shows its correct note ----
% CONFIGURATION:
%   \gnvisXX=1  – node is highlighted (fill=gray!50); its staff note will appear.
%   \gnvisXX=0  – node is plain (fill=gray!10); no staff note for that button.
%   \nvisYY=1   – (default) allow staff note for column k=YY to show.
%   \nvisYY=0   – suppress all staff notes in column k=YY, even when a node there is highlighted.
% Note: multiple nodes in the same column have different pitches; each produces its own note head
%       at the correct vertical position with the correct accidental for that specific button.
%
%   \nvis per column (k=0..XVIII) – set to 0 to mute all notes in that column
\def\nvisZERO{1}   % k= 0  nodes: C4  (gnvisEi)
\def\nvisI{1}      % k= 1  nodes: C#4 (gnvisDi)
\def\nvisII{1}     % k= 2  nodes: Eb4 (gnvisEii), D4 (gnvisCi)
\def\nvisIII{1}    % k= 3  nodes: E4 (gnvisDii), Eb4 (gnvisBi)
\def\nvisIV{1}     % k= 4  nodes: F#4 (gnvisEiii), F4 (gnvisCii), E4 (gnvisAi)
\def\nvisV{1}      % k= 5  nodes: G4 (gnvisDiii), F#4 (gnvisBii)
\def\nvisVI{1}     % k= 6  nodes: A4 (gnvisEiv), Ab4 (gnvisCiii), G4 (gnvisAii)
\def\nvisVII{1}    % k= 7  nodes: Bb4 (gnvisDiv), A4 (gnvisBiii)
\def\nvisVIII{1}   % k= 8  nodes: C5 (gnvisEv), B4 (gnvisCiv), Bb4 (gnvisAiii)
\def\nvisIX{1}     % k= 9  nodes: C#5 (gnvisDv), C5 (gnvisBiv)
\def\nvisX{1}      % k=10  nodes: Eb5 (gnvisEvi), D5 (gnvisCv), C#5 (gnvisAiv)
\def\nvisXI{1}     % k=11  nodes: E5 (gnvisDvi), Eb5 (gnvisBv)
\def\nvisXII{1}    % k=12  nodes: F#5 (gnvisEvii), F5 (gnvisCvi), E5 (gnvisAv)
\def\nvisXIII{1}   % k=13  nodes: G5 (gnvisDvii), F#5 (gnvisBvi)
\def\nvisXIV{1}    % k=14  nodes: A5 (gnvisEviii), Ab5 (gnvisCvii), G5 (gnvisAvi)
\def\nvisXV{1}     % k=15  nodes: Bb5 (gnvisDviii), A5 (gnvisBvii)
\def\nvisXVI{1}    % k=16  nodes: C6 (gnvisEix), B5 (gnvisCviii), Bb5 (gnvisAvii)
\def\nvisXVII{1}   % k=17  nodes: C#6 (gnvisDix), C6 (gnvisBviii)
\def\nvisXVIII{1}  % k=18  nodes: Eb6 (gnvisEx), D6 (gnvisCix), C#6 (gnvisAviii)
%
\pgfmathsetmacro{\hstep}{\staffgap/2}  % cm per diatonic half-line
\pgfmathsetmacro{\xstaffoffset}{3*\halfstep} % shift notes right to align with grid nodes
%
% ---- Per-node staff notes: each highlighted node shows its specific note ----
% \gnvisXX=1 and \nvisYY=1 (where YY=roman of column k) both required to show note.
%
\begin{scope}[shift={(\xstaffoffset,0)}]
%
% gnvisEi  k=0  C4  pos=-2  stem=up  (ledger line below staff)
\ifnum\gnvisEi=1\ifnum\nvisZERO=1
  \draw[black,thin] ({-3*\halfstep-0.20},{\staffbottom-2*\hstep}) -- ({-3*\halfstep+0.20},{\staffbottom-2*\hstep});
  \filldraw[black] ({-3*\halfstep},{\staffbottom-2*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({-3*\halfstep+0.13},{\staffbottom-2*\hstep}) -- ({-3*\halfstep+0.13},{\staffbottom-2*\hstep+0.9});
\fi\fi
%
% gnvisDi  k=1  C#4  pos=-2  stem=up  (ledger line below staff)
\ifnum\gnvisDi=1\ifnum\nvisI=1
  \draw[black,thin] ({-2*\halfstep-0.20},{\staffbottom-2*\hstep}) -- ({-2*\halfstep+0.20},{\staffbottom-2*\hstep});
  \filldraw[black] ({-2*\halfstep},{\staffbottom-2*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({-2*\halfstep+0.13},{\staffbottom-2*\hstep}) -- ({-2*\halfstep+0.13},{\staffbottom-2*\hstep+0.9});
  \node[anchor=base east,inner sep=0pt,font=\small] at ({-2*\halfstep-0.22},{\staffbottom-2*\hstep+0.05}) {$\boldsymbol{\sharp}$};
\fi\fi
%
% gnvisCi  k=2  D4  pos=-1  stem=up
\ifnum\gnvisCi=1\ifnum\nvisII=1
  \filldraw[black] ({-1*\halfstep},{\staffbottom-1*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({-1*\halfstep+0.13},{\staffbottom-1*\hstep}) -- ({-1*\halfstep+0.13},{\staffbottom-1*\hstep+0.9});
\fi\fi
%
% gnvisEii  k=2  Eb4  pos=0  stem=up  (on bottom staff line, bisected by it)
\ifnum\gnvisEii=1\ifnum\nvisII=1
  \filldraw[black] ({-1*\halfstep},{\staffbottom+0*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({-1*\halfstep+0.13},{\staffbottom+0*\hstep}) -- ({-1*\halfstep+0.13},{\staffbottom+0*\hstep+0.9});
  \node[anchor=base east,inner sep=0pt,font=\small] at ({-1*\halfstep-0.22},{\staffbottom+0*\hstep+0.05}) {$\boldsymbol{\flat}$};
\fi\fi
%
% gnvisDii  k=3  E4  pos=0  stem=up
\ifnum\gnvisDii=1\ifnum\nvisIII=1
  \filldraw[black] (0,{\staffbottom+0*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({0+0.13},{\staffbottom+0*\hstep}) -- ({0+0.13},{\staffbottom+0*\hstep+0.9});
\fi\fi
%
% gnvisBi  k=3  Eb4  pos=0  stem=up
\ifnum\gnvisBi=1\ifnum\nvisIII=1
  \filldraw[black] (0,{\staffbottom+0*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({0+0.13},{\staffbottom+0*\hstep}) -- ({0+0.13},{\staffbottom+0*\hstep+0.9});
  \node[anchor=base east,inner sep=0pt,font=\small] at ({0-0.22},{\staffbottom+0*\hstep+0.05}) {$\boldsymbol{\flat}$};
\fi\fi
%
% gnvisAi  k=4  E4  pos=0  stem=up
\ifnum\gnvisAi=1\ifnum\nvisIV=1
  \filldraw[black] (\halfstep,{\staffbottom+0*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({\halfstep+0.13},{\staffbottom+0*\hstep}) -- ({\halfstep+0.13},{\staffbottom+0*\hstep+0.9});
\fi\fi
%
% gnvisEiii  k=4  F#4  pos=1  stem=up
\ifnum\gnvisEiii=1\ifnum\nvisIV=1
  \filldraw[black] (\halfstep,{\staffbottom+1*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({\halfstep+0.13},{\staffbottom+1*\hstep}) -- ({\halfstep+0.13},{\staffbottom+1*\hstep+0.9});
  \node[anchor=base east,inner sep=0pt,font=\small] at ({\halfstep-0.22},{\staffbottom+1*\hstep+0.05}) {$\boldsymbol{\sharp}$};
\fi\fi
%
% gnvisCii  k=4  F4  pos=1  stem=up
\ifnum\gnvisCii=1\ifnum\nvisIV=1
  \filldraw[black] (\halfstep,{\staffbottom+1*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({\halfstep+0.13},{\staffbottom+1*\hstep}) -- ({\halfstep+0.13},{\staffbottom+1*\hstep+0.9});
\fi\fi
%
% gnvisBii  k=5  F#4  pos=1  stem=up
\ifnum\gnvisBii=1\ifnum\nvisV=1
  \filldraw[black] ({2*\halfstep},{\staffbottom+1*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(2*\halfstep)+0.13},{\staffbottom+1*\hstep}) -- ({(2*\halfstep)+0.13},{\staffbottom+1*\hstep+0.9});
  \node[anchor=base east,inner sep=0pt,font=\small] at ({(2*\halfstep)-0.22},{\staffbottom+1*\hstep+0.05}) {$\boldsymbol{\sharp}$};
\fi\fi
%
% gnvisDiii  k=5  G4  pos=2  stem=up
\ifnum\gnvisDiii=1\ifnum\nvisV=1
  \filldraw[black] ({2*\halfstep},{\staffbottom+2*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(2*\halfstep)+0.13},{\staffbottom+2*\hstep}) -- ({(2*\halfstep)+0.13},{\staffbottom+2*\hstep+0.9});
\fi\fi
%
% gnvisAii  k=6  G4  pos=2  stem=up
\ifnum\gnvisAii=1\ifnum\nvisVI=1
  \filldraw[black] ({3*\halfstep},{\staffbottom+2*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(3*\halfstep)+0.13},{\staffbottom+2*\hstep}) -- ({(3*\halfstep)+0.13},{\staffbottom+2*\hstep+0.9});
\fi\fi
%
% gnvisEiv  k=6  A4  pos=3  stem=up
\ifnum\gnvisEiv=1\ifnum\nvisVI=1
  \filldraw[black] ({3*\halfstep},{\staffbottom+3*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(3*\halfstep)+0.13},{\staffbottom+3*\hstep}) -- ({(3*\halfstep)+0.13},{\staffbottom+3*\hstep+0.9});
\fi\fi
%
% gnvisCiii  k=6  Ab4  pos=3  stem=up
\ifnum\gnvisCiii=1\ifnum\nvisVI=1
  \filldraw[black] ({3*\halfstep},{\staffbottom+3*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(3*\halfstep)+0.13},{\staffbottom+3*\hstep}) -- ({(3*\halfstep)+0.13},{\staffbottom+3*\hstep+0.9});
  \node[anchor=base east,inner sep=0pt,font=\small] at ({(3*\halfstep)-0.22},{\staffbottom+3*\hstep+0.05}) {$\boldsymbol{\flat}$};
\fi\fi
%
% gnvisBiii  k=7  A4  pos=3  stem=up
\ifnum\gnvisBiii=1\ifnum\nvisVII=1
  \filldraw[black] ({4*\halfstep},{\staffbottom+3*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(4*\halfstep)+0.13},{\staffbottom+3*\hstep}) -- ({(4*\halfstep)+0.13},{\staffbottom+3*\hstep+0.9});
\fi\fi
%
% gnvisDiv  k=7  Bb4  pos=4  stem=down
\ifnum\gnvisDiv=1\ifnum\nvisVII=1
  \filldraw[black] ({4*\halfstep},{\staffbottom+4*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(4*\halfstep)-0.13},{\staffbottom+4*\hstep}) -- ({(4*\halfstep)-0.13},{\staffbottom+4*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\small] at ({(4*\halfstep)-0.22},{\staffbottom+4*\hstep+0.05}) {$\boldsymbol{\flat}$};
\fi\fi
%
% gnvisCiv  k=8  B4  pos=4  stem=down
\ifnum\gnvisCiv=1\ifnum\nvisVIII=1
  \filldraw[black] ({5*\halfstep},{\staffbottom+4*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(5*\halfstep)-0.13},{\staffbottom+4*\hstep}) -- ({(5*\halfstep)-0.13},{\staffbottom+4*\hstep-0.9});
\fi\fi
%
% gnvisAiii  k=8  Bb4  pos=4  stem=down
\ifnum\gnvisAiii=1\ifnum\nvisVIII=1
  \filldraw[black] ({5*\halfstep},{\staffbottom+4*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(5*\halfstep)-0.13},{\staffbottom+4*\hstep}) -- ({(5*\halfstep)-0.13},{\staffbottom+4*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\small] at ({(5*\halfstep)-0.22},{\staffbottom+4*\hstep+0.05}) {$\boldsymbol{\flat}$};
\fi\fi
%
% gnvisEv  k=8  C5  pos=5  stem=down
\ifnum\gnvisEv=1\ifnum\nvisVIII=1
  \filldraw[black] ({5*\halfstep},{\staffbottom+5*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(5*\halfstep)-0.13},{\staffbottom+5*\hstep}) -- ({(5*\halfstep)-0.13},{\staffbottom+5*\hstep-0.9});
\fi\fi
%
% gnvisDv  k=9  C#5  pos=5  stem=down
\ifnum\gnvisDv=1\ifnum\nvisIX=1
  \filldraw[black] ({6*\halfstep},{\staffbottom+5*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(6*\halfstep)-0.13},{\staffbottom+5*\hstep}) -- ({(6*\halfstep)-0.13},{\staffbottom+5*\hstep-0.9});
