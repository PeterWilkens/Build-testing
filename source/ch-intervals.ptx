\ifnum\gnvisBv=1\ifnum\nvisXI=1
  \filldraw[black] ({8*\halfstep},{\staffbottom+7*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(8*\halfstep)-0.13},{\staffbottom+7*\hstep}) -- ({(8*\halfstep)-0.13},{\staffbottom+7*\hstep-0.9});
