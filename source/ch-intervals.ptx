\ifnum\gnvisEvii=1\ifnum\nvisXII=1
  \filldraw[black] ({9*\halfstep},{\staffbottom+8*\hstep}) ellipse (0.14 and 0.09);
  \draw[black,thin] ({(9*\halfstep)-0.13},{\staffbottom+8*\hstep}) -- ({(9*\halfstep)-0.13},{\staffbottom+8*\hstep-0.9});
  \node[anchor=base east,inner sep=0pt,font=\small] at ({(9*\halfstep)-0.22},{\staffbottom+8*\hstep+0.05}) {$\boldsymbol{\sharp}$};
