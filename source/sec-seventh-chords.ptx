\gn{1}{4.5}{G}{0}
\gn{5}{3.5}{G$\flat$, F$\sharp$}{0}
\gn{4}{4}{G}{1}
\gn{3}{4.5}{A$\flat$, G$\sharp$}{0}
\gn{2}{5}{A}{0}
\gn{1}{5.5}{B$\flat$, A$\sharp$}{0}
\gn{5}{4.5}{A}{0}
\gn{4}{5}{B$\flat$, A$\sharp$}{0}
\gn{3}{5.5}{B}{1}
\gn{2}{6}{C}{0}
\gn{1}{6.5}{C$\sharp$, D$\flat$}{0}
\gn{5}{5.5}{C}{0}
\gn{4}{6}{C$\sharp$, D$\flat$}{0}
\gn{3}{6.5}{D}{0}
\gn{2}{7}{E$\flat$, D$\sharp$}{0}
\gn{1}{7.5}{E}{0}
\gn{5}{6.5}{E$\flat$, D$\sharp$}{0}
\gn{4}{7}{E}{0}
\gn{3}{7.5}{F}{0}
\gn{2}{8}{G$\flat$, F$\sharp$}{0}
\gn{1}{8.5}{G}{0}
\draw[black!40, semithick, rounded corners=6pt] ({3*\hlen- 0.60},{1.5*\vlen- 0.60}) rectangle ({5*\hlen+ 0.60},{5.5*\vlen+ 0.60});
\end{tikzpicture}
